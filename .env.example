# LeadScan — Environment Configuration
# Copy this to .env and fill in your values

# ── SERVER ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── SECURITY ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_random_long_string_251972

# ── DATABASE ──────────────────────────────────────────────────
DB_PATH=./leadscan.db

# ── CORS ──────────────────────────────────────────────────────
# Your frontend domain (no trailing slash)
ALLOWED_ORIGIN=https://www.wokeey.com

# ── EMAIL — OPTION A: Gmail ───────────────────────────────────
# Generate App Password: myaccount.google.com/apppasswords
GMAIL_USER=domaincart112@gmail.com
GMAIL_APP_PASS=wjei gmim wsjp acqj

# ── EMAIL — OPTION B: Custom SMTP ────────────────────────────
# (comment out GMAIL_ vars above if using this)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key

# From address shown in email
EMAIL_FROM="LeadScan" <info@wokeey.com>
